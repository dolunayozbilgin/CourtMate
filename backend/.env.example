# ── Supabase PostgreSQL bağlantısı ──────────────────────────
# Supabase dashboard → Project Settings → Database → Connection string
# "URI" sekmesinden al, [YOUR-PASSWORD] kısmını kendi şifrenle değiştir

DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ── JWT ─────────────────────────────────────────────────────
# Rastgele uzun bir string yaz (en az 32 karakter)
# Örnek üretmek için: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"

JWT_SECRET=buraya_cok_uzun_ve_rastgele_bir_string_yaz
JWT_EXPIRES_IN=7d

# ── Sunucu ──────────────────────────────────────────────────
PORT=3001

# ── Frontend URL (CORS için) ─────────────────────────────────
# Localda geliştirme yaparken:
FRONTEND_URL=http://localhost:3000
# Netlify'a attıysan:
# FRONTEND_URL=https://courtmate.netlify.app
